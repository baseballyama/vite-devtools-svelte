{
  "name": "vite-devtools-svelte",
  "version": "0.1.1",
  "description": "Svelte DevTools plugin for Vite DevTools",
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/vite-devtools-svelte.git",
    "directory": "packages/vite-devtools-svelte"
  },
  "homepage": "https://github.com/baseballyama/vite-devtools-svelte#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/vite-devtools-svelte/issues"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "vite-devtools",
    "svelte",
    "sveltekit",
    "devtools"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vitejs/devtools-kit": "^0.1.21"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  }
}
