{
  "name": "vite-devtools-svelte-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "pnpm -C packages/vite-devtools-svelte/client build",
    "build:plugin": "pnpm -C packages/vite-devtools-svelte build",
    "build": "pnpm build:plugin && pnpm build:client",
    "dev": "pnpm build && pnpm -C playground dev",
    "dev:ui": "pnpm build && pnpm -C playground dev:ui",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ]
    }
  }
}
