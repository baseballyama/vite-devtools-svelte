{
  "name": "vite-devtools-svelte-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "pnpm -C packages/vite-devtools-svelte/client build",
    "build:plugin": "pnpm -C packages/vite-devtools-svelte build",
    "build": "pnpm build:plugin && pnpm build:client",
    "dev": "pnpm -C playground dev",
    "dev:ui": "pnpm -C playground dev:ui",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0"
  },
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ]
    }
  }
}
